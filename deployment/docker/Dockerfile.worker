FROM python:3.12-slim

WORKDIR /app

# System deps for torch
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ curl \
    && rm -rf /var/lib/apt/lists/*

# Install CPU torch first (GPU passthrough handled by nvidia runtime)
RUN pip install --no-cache-dir \
    torch==2.3.0 \
    transformers==4.41.0 \
    accelerate==0.30.0 \
    sentencepiece==0.2.0 \
    fastapi==0.111.0 \
    uvicorn[standard]==0.29.0 \
    pydantic==2.7.1 \
    pydantic-settings==2.2.1 \
    prometheus-client==0.20.0 \
    python-dotenv==1.0.1 \
    structlog==24.1.0 \
    redis==5.0.4 \
    httpx==0.27.0

COPY config.py .
COPY inference_worker/ ./inference_worker/
COPY request_queue/ ./request_queue/

# Pre-cache model weights at build time (optional — comment out to skip)
# RUN python -c "from transformers import AutoModelForCausalLM, AutoTokenizer; AutoTokenizer.from_pretrained('gpt2'); AutoModelForCausalLM.from_pretrained('gpt2')"

EXPOSE 8002

CMD ["python", "-m", "uvicorn", "inference_worker.main:app", "--host", "0.0.0.0", "--port", "8002", "--log-level", "info", "--timeout-keep-alive", "120"]
