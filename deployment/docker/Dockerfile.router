FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi==0.111.0 \
    uvicorn[standard]==0.29.0 \
    httpx==0.27.0 \
    pydantic==2.7.1 \
    pydantic-settings==2.2.1 \
    prometheus-client==0.20.0 \
    python-dotenv==1.0.1 \
    structlog==24.1.0

COPY config.py .
COPY router/ ./router/

EXPOSE 8001

CMD ["python", "-m", "uvicorn", "router.main:app", "--host", "0.0.0.0", "--port", "8001", "--log-level", "info"]
